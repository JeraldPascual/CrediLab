<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background_dark"
    tools:context=".AchievementsActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_dark"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/background_dark"
            app:titleTextColor="@color/text_primary" />
            
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Achievements &amp; Credentials"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:drawablePadding="8dp"
                app:drawableStartCompat="@drawable/ic_trophy" />
                
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your skill rank and employer credentials based on total CLB earned."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"/>

            <!-- Current Rank Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <include layout="@layout/layout_mac_dots" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        
                        <com.example.credilabmobile.TierFrameView
                            android:id="@+id/tfvCurrentRank"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="16dp"/>
                            
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/tfvCurrentRank"
                            android:layout_toStartOf="@id/llRankStats"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CURRENT RANK"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.1" />
                                
                            <TextView
                                android:id="@+id/tvCurrentRankTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Apprentice Developer"
                                android:textColor="@color/primary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp"/>
                                
                            <TextView
                                android:id="@+id/tvCurrentRankDesc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Solving basic problems with confidence."
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/llRankStats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:gravity="end"
                            android:orientation="vertical">
                            
                            <TextView
                                android:id="@+id/tvTotalClb"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="50"
                                android:textColor="@color/success"
                                android:textSize="24sp"
                                android:textStyle="bold" />
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CLB earned (lifetime)"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"/>
                                
                            <TextView
                                android:id="@+id/tvChallengesSolved"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1 challenge solved"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp"
                                android:textStyle="bold"/>
                                
                            <TextView
                                android:id="@+id/tvSpendableClb"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 CLB spendable"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </RelativeLayout>
                    
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#33FFFFFF"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="20dp"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        
                        <TextView
                            android:id="@+id/tvProgressLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Progress to"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />
                            
                        <TextView
                            android:id="@+id/tvNextRank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/tvProgressLabel"
                            android:layout_marginStart="4dp"
                            android:text="Junior"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvProgressValues"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="50 / 130 CLB"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                    <ProgressBar
                        android:id="@+id/pbRankProgress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progressDrawable="@drawable/bg_progress_bar_rank"
                        android:max="100"
                        android:progress="38" />
                        
                    <TextView
                        android:id="@+id/tvRemainingClb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="80 CLB to reach Junior Programmer"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"/>
                        
                    <!-- Badges Preview Row inside Card -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginTop="12dp">
                        <LinearLayout
                            android:id="@+id/llRecentBadges"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#33FFFFFF"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Employer Credential: Your rank is publicly visible on the CrediLab leaderboard. Employers can verify your coding level by searching your name."
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Spending CLB Info Box -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Spending CLB"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                        
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Send CLB tokens directly to the cafeteria wallet via MetaMask. Your rank is never affected — it is based on your lifetime earned total, not your current balance."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"/>
                        
                    <TextView
                        android:id="@+id/tvCurrentSpendableBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Current spendable balance: 0 CLB"
                        android:textColor="@color/success"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#1AFFFFFF"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Need more to spend or rank up?"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Connect to credilab.vercel.app on your computer to solve advanced challenges and earn massive amounts of CLB!"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenWebPromoAchievements"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="8dp"
                        android:text="Visit Web Platform"
                        android:textColor="@color/primary"
                        app:icon="@android:drawable/ic_menu_directions"
                        app:iconTint="@color/primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tabs -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_dark"
                app:tabIndicatorColor="@color/primary"
                app:tabSelectedTextColor="@color/primary"
                app:tabTextColor="@color/text_secondary"
                app:tabMode="fixed">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skill Tiers" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Badges" />
                    
            </com.google.android.material.tabs.TabLayout>
            
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:minHeight="400dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSkillTiers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingBottom="24dp"
                    android:nestedScrollingEnabled="false" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvBadges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingBottom="24dp"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
